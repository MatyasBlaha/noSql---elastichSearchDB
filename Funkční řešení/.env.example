# Heslo pro uživatele 'elastic' (superuser - login do Kibany, ES API, Elasticvue)
# Min 6 znaků. Pro produkci POVINNĚ změnit!
ELASTIC_PASSWORD=changeme

# Heslo pro service account 'kibana_system' (interní – Kibana <-> ES komunikace)
# Uživatel ho do žádného loginu nezadává, je jen v této env proměnné.
KIBANA_PASSWORD=changeme

# Verze ELK stacku (Elasticsearch, Logstash, Kibana – stejná pro celý stack)
STACK_VERSION=8.17.0

# Název clusteru (musí být stejný na všech 4 uzlech)
CLUSTER_NAME=spotify-elk-cluster

# Licence (basic = zdarma, trial = 30 dní plná verze)
LICENSE=basic

# Port pro Elasticsearch HTTP API (mapováno z es-data-1)
ES_PORT=9200

# Port pro Kibana webové rozhraní
KIBANA_PORT=5601

# RAM limity pro kontejnery (v bytech)
# Master uzel – 2 GiB. Vyšší než data uzly kvůli bootstrap fázi (ILM policies,
# APM templates, security indexy). Nižší limit (1 GiB) způsoboval OOM kill.
MEM_LIMIT_MASTER=2147483648

# Data uzly + Kibana + Logstash – 1.5 GiB. JVM heap 512 MB + 1 GiB rezerva
# pro Lucene off-heap cache, JVM metaspace, native memory shard operací.
MEM_LIMIT_DATA=1610612736
